{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  // src/worker.ts is checked by tsconfig.worker.json instead: its Workers
  // globals (D1Database, ScheduledEvent) need @cloudflare/workers-types,
  // and loading those into a types:["node"] program declares fetch/crypto/
  // Request twice.
  "exclude": ["node_modules", "dist", "src/worker.ts"]
}
