{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/landing10.html", "destination": "/", "statusCode": 308 }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.vivek-patel.com/api/:path*" },
    { "source": "/console", "destination": "/console.html" },
    { "source": "/((?!api/).*)", "destination": "/console.html" }
  ]
}
